function persistent_ssh --description 'Устанавливает SSH-соединение с автопереподключением при обрыве'
    set -l target $argv
    
    while true
        ssh $target
        
        # Если ssh завершился штатно (например, по команде exit с кодом 0), выходим из цикла
        if test $status -eq 0
            echo "Сессия завершена штатно."
            break
        end
        
        # Если произошел обрыв (ребут сервера, отвал сети), ждем и пробуем снова
        echo "[!] Соединение разорвано. Ожидание сервера для переподключения..."
        sleep 5
    end
end
